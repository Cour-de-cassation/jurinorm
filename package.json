{
  "name": "jurinorm",
  "version": "0.0.1",
  "private": true,
  "description": "Jurinorm",
  "license": "MIT",
  "author": "Cour de cassation",
  "scripts": {
    "build": "tsc --build && tsc-alias",
    "fix": "eslint \"src/**/*.ts\" --fix && prettier \"src/**/*.ts\" --write",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "format": "prettier \"src/**/*.ts\" --check",
    "start": "npx ts-node -r tsconfig-paths/register -r dotenv/config src/batch.ts",
    "start:watch": "nodemon --config nodemon.json",
    "start:docker": "docker compose up",
    "test": "jest && npm run test:integration",
    "test:cov": "jest --coverage",
    "test:integration": "jest --config ./jest-integration.json --runInBand",
    "scripts:tj:reprocessStockDecisions": "docker compose run --rm jurinorm-batch npx ts-node /home/node/src/tj/script/reprocessStockDecisions.ts",
    "scripts:tcom:reprocessStockDecisions": "docker compose run --rm jurinorm-batch npx ts-node /home/node/src/tcom/script/reprocessStockDecisions.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1050.0",
    "@nestjs/common": "11.1.21",
    "axios": "1.16.1",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "dbsder-api-types": "3.0.6",
    "dotenv": "17.4.2",
    "entities": "7.0.1",
    "fast-xml-parser": "5.3.2",
    "form-data": "4.0.5",
    "html-entities": "2.6.0",
    "html-to-text": "10.0.0",
    "joi": "18.2.1",
    "jsdom": "26.1.0",
    "mongodb": "7.2.0",
    "nestjs-pino": "4.6.1",
    "pdf-lib": "1.17.1",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "reflect-metadata": "0.2.2",
    "uuid": "11.1.1",
    "zod": "4.4.3",
    "zod-mongodb-schema": "3.0.2"
  },
  "devDependencies": {
    "@smithy/util-stream": "4.6.3",
    "@types/express": "5.0.6",
    "@types/html-to-text": "9.0.4",
    "@types/jest": "30.0.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/multer": "2.1.0",
    "@types/node": "24.10.9",
    "@types/uuid": "11.0.0",
    "aws-sdk-client-mock": "4.1.0",
    "aws-sdk-client-mock-jest": "4.1.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "jest": "30.4.2",
    "mongodb-memory-server": "11.1.0",
    "nodemon": "3.1.14",
    "pino-pretty": "13.1.3",
    "prettier": "3.8.3",
    "ts-jest": "29.4.10",
    "ts-loader": "9.5.7",
    "ts-node": "10.9.2",
    "tsc-alias": "1.8.17",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.4"
  }
}